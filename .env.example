# Copy to .env and fill in. NO API KEY is needed for this project — the demo,
# tests, and even live scraping run for free.

# Optional: override the live scrape target (used only with --live).
# Default is the books.toscrape.com sandbox. Point this at a client's target
# site (and update the selectors in src/scrape.py to match its markup).
# TARGET_URL=https://books.toscrape.com/catalogue/page-{n}.html
